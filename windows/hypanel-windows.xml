<?xml version="1.0" encoding="UTF-8"?>
<service>
  <id>hypanel</id>
  <name>HyPanel Proxy Panel</name>
  <description>HyPanel is a proxy panel for managing proxy services</description>
  <executable>%BASE%\hypanel.exe</executable>
  <arguments></arguments>
  <logmode>rotate</logmode>
  <logpath>%BASE%\logs</logpath>
  <log size="10 m" />
  <log keep="10" />
  <workingdirectory>%BASE%</workingdirectory>
  <env name="HYPANEL_DB_FOLDER" value="db" />
  <env name="HYPANEL_DEBUG" value="false" />
  <onfailure action="restart" delay="10 sec" />
  <onfailure action="restart" delay="20 sec" />
  <onfailure action="none" />
  <resetfailure>1 hour</resetfailure>
  <startmode>Automatic</startmode>
  <depend>tcpip</depend>
  <depend>netman</depend>
</service>
